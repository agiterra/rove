{
  "name": "@agiterra/rove-core",
  "version": "0.0.0-alpha.13",
  "description": "Rove core — types, schemas, prompts shared between the CLI, daemon, and dashboard.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/agiterra/rove.git",
    "directory": "packages/core"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./authoring-schemas": {
      "types": "./dist/authoring-schemas.d.ts",
      "import": "./dist/authoring-schemas.js",
      "default": "./dist/authoring-schemas.js"
    }
  },
  "publishConfig": {
    "access": "restricted",
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  }
}

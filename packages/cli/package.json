{
  "name": "@rove/cli",
  "version": "0.0.0-alpha.1",
  "description": "Rove CLI + daemon. Walks your app as personas and agents, files findings, integrates with the Rove dashboard.",
  "bin": {
    "rove": "./bin/rove.js"
  },
  "files": [
    "bin",
    "dist"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@rove/core": "workspace:*",
    "@supabase/supabase-js": "^2.105.4",
    "commander": "^12.1.0",
    "marked": "^14.1.4",
    "playwright": "1.60.0-alpha-2026-05-06",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  }
}

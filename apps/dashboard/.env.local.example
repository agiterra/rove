# Public (sent to the browser; safe — RLS gates reads on the server.):
NEXT_PUBLIC_SUPABASE_URL=https://tceosllezmydpouvfuzf.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_BI1DyMHbpTNZ9BNqCNR0Dw_9F1CNEEA

# Server-only — bypasses RLS. Used for minting signed Storage URLs and the
# dev bypass below. NEVER prefix with NEXT_PUBLIC_.

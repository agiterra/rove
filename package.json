{
  "name": "rove",
  "version": "0.0.0-alpha.28",
  "private": true,
  "description": "Rove — agentic UX evaluation for the agent-readable web. Explore. Observe. Report.",
  "homepage": "https://github.com/agiterra/rove",
  "license": "UNLICENSED",
  "author": "Agiterra",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/agiterra/rove.git"
  },
  "type": "module",
  "scripts": {
    "build": "pnpm -r --filter=./packages/* --filter=./apps/* build",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "dashboard": "pnpm --filter @agiterra/rove-dashboard dev",
    "cli": "pnpm --filter @agiterra/rove-cli build && bash scripts/run-cli.sh",
    "daemon": "pnpm --filter @agiterra/rove-cli build && bash scripts/run-cli.sh daemon",
    "sync:agent-guides": "node scripts/sync-agent-guides.mjs"
  },
  "engines": {
    "node": ">=22.13.0"
  },
  "packageManager": "pnpm@10.15.0",
  "devDependencies": {
    "@supabase/supabase-js": "^2.105.4",
    "playwright": "^1.60.0"
  }
}
